APP_NAME="Techxx"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=techxx
DB_USERNAME=root
DB_PASSWORD=

# Redis (optional - if you use Redis for cache/session)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Session & Cache
SESSION_DRIVER=file
CACHE_DRIVER=file

# Mail (optional - for sending notifications)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ======================
# خدمات التكامل الخارجي
# ======================

# النفاذ الوطني (للأفراد)
NAFATH_CLIENT_ID=your_nafath_client_id
NAFATH_CLIENT_SECRET=your_nafath_client_secret
NAFATH_REDIRECT_URI=${APP_URL}/auth/nafath/callback
NAFATH_AUTH_BASE=https://nafath.sa
NAFATH_API_BASE=https://api.nafath.sa

# توثيق (للمنشآت)
TAWTHEEQ_CLIENT_ID=your_tawtheeq_client_id
TAWTHEEQ_CLIENT_SECRET=your_tawtheeq_client_secret
TAWTHEEQ_REDIRECT_URI=${APP_URL}/auth/tawtheeq/callback
TAWTHEEQ_AUTH_BASE=https://tawtheeq.sa
TAWTHEEQ_API_BASE=https://api.tawtheeq.sa

# Lean (Open Banking)
LEAN_APP_ID=your_lean_app_id
LEAN_APP_SECRET=your_lean_app_secret
LEAN_WEBHOOK_SECRET=your_lean_webhook_secret
LEAN_REDIRECT_URL=${APP_URL}/customer/accounts/callback
LEAN_BASE_URL=https://api.lean.dev
LEAN_CONNECT_URL=https://connect.lean.dev

# سداد (Sadad)
SADAD_MERCHANT_ID=your_sadad_merchant_id
SADAD_MERCHANT_SECRET=your_sadad_merchant_secret
SADAD_ACCESS_TOKEN=   # Optional: يمكن الحصول عليه لاحقاً عبر المصادقة
SADAD_BASE_URL=https://api.sadad.sa

# ======================
# إعدادات إضافية
# ======================

# Logging
LOG_CHANNEL=stack

# Broadcasting
BROADCAST_DRIVER=log
