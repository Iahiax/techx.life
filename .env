# ============================================
# الإعدادات الأساسية للتطبيق
# ============================================
APP_NAME="techx.life"
APP_ENV=production
APP_KEY=base64:8kqAzrHBf9Vvs96r8Pqx3TDCunHaSn+7XBfjda0lBz4=
APP_DEBUG=false
APP_URL=https://techx.life           # غيّره إلى رابط موقعك الفعلي
ASSET_URL=https://techx.life

# ============================================
# إعدادات قاعدة البيانات (تأكد من صحة هذه القيم)
# ============================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=techtjsc_techx.life                     # اسم قاعدة البيانات التي أنشأتها
DB_USERNAME=techtjsc_yahiax                    # اسم المستخدم
DB_PASSWORD=Yahia-1411@848200          # كلمة المرور

# ============================================
# إعدادات الجلسة والكاش
# ============================================
SESSION_DRIVER=file
CACHE_DRIVER=file

# ============================================
# إعدادات البريد (اختياري – يمكن تركها)
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@techx.life
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# مفتاح سري للمجدول والصفوف (للأمان – اختر قيمة قوية)
# ============================================
CRON_SECRET=your_random_secret_key_here_change_it

# ============================================
# خدمات المصادقة الخارجية (نفاذ – توثيق)
# ============================================
# النفاذ الوطني (للأفراد)
NAFATH_CLIENT_ID=your_nafath_client_id
NAFATH_CLIENT_SECRET=your_nafath_client_secret
NAFATH_REDIRECT_URI=${APP_URL}/auth/nafath/callback
NAFATH_AUTH_BASE=https://nafath.sa
NAFATH_API_BASE=https://api.nafath.sa

# توثيق (للمنشآت)
TAWTHEEQ_CLIENT_ID=your_tawtheeq_client_id
TAWTHEEQ_CLIENT_SECRET=your_tawtheeq_client_secret
TAWTHEEQ_REDIRECT_URI=${APP_URL}/auth/tawtheeq/callback
TAWTHEEQ_AUTH_BASE=https://tawtheeq.sa
TAWTHEEQ_API_BASE=https://api.tawtheeq.sa

# ============================================
# خدمات التكامل البنكي (Lean)
# ============================================
LEAN_APP_ID=your_lean_app_id
LEAN_APP_SECRET=your_lean_app_secret
LEAN_WEBHOOK_SECRET=your_lean_webhook_secret
LEAN_REDIRECT_URL=${APP_URL}/customer/accounts/callback
LEAN_BASE_URL=https://api.lean.dev
LEAN_CONNECT_URL=https://connect.lean.dev

# ============================================
# خدمات سداد (اختياري – اتركه كما هو إذا لم تستخدمه)
# ============================================
SADAD_MERCHANT_ID=your_sadad_merchant_id
SADAD_MERCHANT_SECRET=your_sadad_merchant_secret
SADAD_ACCESS_TOKEN=
SADAD_BASE_URL=https://api.sadad.sa
